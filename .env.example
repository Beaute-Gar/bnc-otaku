# =============================================================================
# BNC-OTAKU — Template .env (copier vers .env et remplir)
# =============================================================================

# === IA Gemini (obligatoire pour générer les questions) ===
# Obtenir une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# === MySQL ===
DB_HOST="localhost"
DB_PORT=3306
DB_USER="root"
DB_PASSWORD=""
DB_NAME="bnc_otaku_db"
DB_SSL_CA=""        # Chemin CA cert (Aiven) ou laisser vide
DB_SSL_MODE="DISABLED"  # "DISABLED" ou "REQUIRED"

# === Sécurité API (changer impérativement en production) ===
API_SECRET_KEY="bnc-otaku-secret-key-change-me-2026"
API_RATE_LIMIT="100/minute"
CSRF_SECRET="bnc-otaku-csrf-secret-change-me"

# === Telegram Bot ===
# Créer via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_URL=""

# === WhatsApp Meta Business API ===
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""
META_WEBHOOK_VERIFY_TOKEN="bnc-verify-2026"
META_WEBHOOK_URL=""

# === WhatsApp Playwright (alternative sans Meta Business) ===
WHATSAPP_SESSION_DIR="./wa_sessions"
WHATSAPP_HEADLESS=false

# === CinetPay (Mobile Money — MTN/Orange) ===
# Inscription : https://cinetpay.com
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""

# === NotchPay (alternative CinetPay) ===
NOTCHPAY_PUBLIC_KEY=""

# === Admin ===
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2b$12$JBdUjjqpTJofUsbSNq7J0uJXfkcBess/HCqf6ZTqc/7Ma6e6zR3c2"
ADMIN_EMAIL="admin@bnc-otaku.cm"

# === Frontend (changer en prod) ===
# En local : http://localhost:8000
# Sur Render : https://bnc-otaku.onrender.com
FRONTEND_URL="http://localhost:8000"
CORS_ORIGINS="http://localhost:8000,http://localhost:5500"
